<Window x:Class="lockin.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lockin.wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
   
<Grid Margin="20">
    <StackPanel>
        <TextBlock Text="Welcome to LockIn Trivia!" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20" 
                   HorizontalAlignment="Center"/>
        
        <TextBlock Text="Select a Topic to Start:" 
                   FontSize="16" 
                   Margin="0,0,0,10"/>
        
        <ListBox ItemsSource="{Binding Topics}" Height="200">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding TopicName}" FontSize="14" Padding="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Grid>
    
</Window>
