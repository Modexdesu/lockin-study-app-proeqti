<Window x:Class="lockin.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LockIn Trivia Matcher" Height="550" Width="800"
        Background="#121212">
    <!-- Dark Background -->

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: CREATION & GAME SETTINGS -->
        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="Welcome to LockIn Trivia!" FontSize="22" FontWeight="Bold" Foreground="LightSkyBlue" Margin="0,0,0,15" />

            <!-- ADD TOPIC SECTION -->
            <TextBlock Text="Create New Topic Category:" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding NewTopicName, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="6" FontSize="13" VerticalContentAlignment="Center" Background="#1E1E1E" Foreground="White" BorderBrush="LightSkyBlue"/>
                <Button Grid.Column="1" Content="Add Topic" 
                        Command="{Binding AddTopicCommand}" 
                        Background="LightSkyBlue" Foreground="Black" FontWeight="Bold"
                        Width="90" Margin="5,0,0,0" Padding="5,0" BorderThickness="0"/>
            </Grid>

            <!-- THE TOPICS LIST -->
            <TextBlock Text="Available Topic Categories:" FontSize="14" Foreground="White" Margin="0,5,0,5"/>
            <ListBox ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}" Height="180" Background="#1E1E1E" Foreground="White" BorderBrush="#333">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding TopicName}" FontSize="14" Padding="4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- DIFFICULTY SLIDER -->
            <TextBlock Text="{Binding GameDifficulty, StringFormat='Choose Match Difficulty Level: {0}'}" 
                       FontSize="14" Margin="0,15,0,5" FontWeight="SemiBold" Foreground="White"/>
            <Slider Minimum="1" Maximum="3" 
                    Value="{Binding GameDifficulty}" 
                    IsSnapToTickEnabled="True" TickFrequency="1" 
                    Margin="0,0,0,5" Foreground="LightSkyBlue"/>
            <Grid Margin="5,0,5,0">
                <TextBlock Text="Easy (1)" HorizontalAlignment="Left" Foreground="#AAA" FontSize="11"/>
                <TextBlock Text="Medium (2)" HorizontalAlignment="Center" Foreground="#AAA" FontSize="11"/>
                <TextBlock Text="Hard (3)" HorizontalAlignment="Right" Foreground="#AAA" FontSize="11"/>
            </Grid>

            <!-- START BUTTON -->
            <Button Content=" LOCK-IN" 
                    Command="{Binding StartGameCommand}"
                    Background="LightSkyBlue" Foreground="Black" 
                    FontSize="16" FontWeight="Bold" 
                    Padding="15,10" Margin="0,20,0,0" BorderThickness="0"/>
        </StackPanel>

        <!-- RIGHT COLUMN: ADMINISTRATIVE CONTEXT -->
        <Border Grid.Column="1" Background="#1E1E1E" Padding="15" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Topic Administration Panel" FontSize="16" FontWeight="Bold" Foreground="LightSkyBlue" Margin="0,0,0,15"/>

                <!-- Update Row -->
                <TextBlock Text="Rename Highlighted Topic:" FontSize="12" Foreground="White" Margin="0,0,0,2"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding EditTopicName, UpdateSourceTrigger=PropertyChanged}" Padding="5" FontSize="13" Background="#121212" Foreground="White" BorderBrush="#555"/>
                    <Button Grid.Column="1" Content="Save" Command="{Binding UpdateTopicCommand}" Background="LightSkyBlue" Foreground="Black" FontWeight="SemiBold" Width="60" Margin="5,0,0,0" BorderThickness="0"/>
                </Grid>

                <!-- Delete Row -->
                <TextBlock Text="Danger Zone:" FontSize="12" Margin="0,10,0,2" Foreground="Firebrick" FontWeight="Bold"/>
                <Button Content="Delete Selected Category" 
                        Command="{Binding DeleteTopicCommand}" 
                        Background="Firebrick" Foreground="White" Padding="8" FontWeight="SemiBold" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>