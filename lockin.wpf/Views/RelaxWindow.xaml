<Window x:Class="lockin.wpf.Views.RelaxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Take a Break" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" Topmost="True" ResizeMode="NoResize"
        Background="#19334d">
    <!-- Deep Black Background -->

    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="taking a break?" FontWeight="Bold" 
                   FontSize="16" TextAlignment="Center" Margin="0,0,0,20" Foreground="White"/>

        <!-- Break Options (Blue) -->
        <Button Content="10 Minutes" Margin="0,5" Padding="8" Click="BtnDuration_Click" Tag="10"
                Background="#1affff" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

        <Button Content="30 Minutes" Margin="0,5" Padding="8" Click="BtnDuration_Click" Tag="30"
                Background="#1affff" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

        <Button Content="1 Hour" Margin="0,5" Padding="8" Click="BtnDuration_Click" Tag="60"
                Background="#1affff" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

        <!-- The Escape Hatch (Red) -->
        <Button Content="END SESSION COMPLETELY" Margin="0,20,0,0" Padding="8" 
                Click="BtnStop_Click" Background="#990000" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
    </StackPanel>
</Window>